{% extends 'base.html.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block body %}
    <div class="page__header">
        <div>
            <h1 class="page__title">Hey, {{ app.user.firstName }}</h1>
            <p class="page__subtitle">Voici ce qui a bougé depuis votre dernière visite.</p>
        </div>
    </div>

    <div class="stack stack--lg">
        <section class="stack">
            <h2>Mentions et réponses</h2>
            {% if mentions|length > 0 %}
                <div class="grid-2">
                    {% for comment in mentions %}
                        <article class="card">
                            <h3 class="card__title">
                                <a href="{{ path('app_projects_show', {reference: comment.project.reference}) }}">
                                    {{ comment.project.reference }}
                                </a>
                                <span class="text-muted text-sm" style="font-family: var(--font-sans); font-weight: 400;">· {{ comment.project.title }}</span>
                            </h3>
                            <p class="card__subtitle">{{ comment.author.fullName }} · {{ comment.createdAt|format_datetime('short', 'short', locale='fr') }}</p>
                            <p>« {{ comment.body|u.truncate(180, '…') }} »</p>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted">Aucune mention récente. ✦</p>
            {% endif %}
        </section>

        <section class="stack">
            <h2>Mes tâches</h2>
            {% if tasks|length > 0 %}
                <div class="card">
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        {% for task in tasks %}
                            <li style="display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) 0; border-bottom: 1px solid var(--color-line);">
                                {{ ux_icon('lucide:square') }}
                                <span style="flex: 1;">{{ task.title }}</span>
                                <a href="{{ path('app_projects_show', {reference: task.project.reference}) }}" class="text-xs text-muted">{{ task.project.reference }}</a>
                                {% if task.dueDate %}<span class="tag">{{ task.dueDate|format_date('short', locale='fr') }}</span>{% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% else %}
                <p class="text-muted">Aucune tâche en cours.</p>
            {% endif %}
        </section>

        <section class="stack">
            <h2>Activité récente</h2>
            <div class="card">
                <ul style="list-style: none; padding: 0; margin: 0;">
                    {% for log in recent_activity %}
                        <li style="display: flex; align-items: baseline; gap: var(--space-3); padding: var(--space-2) 0; border-bottom: 1px solid var(--color-line);">
                            <span class="text-xs text-muted" style="min-width: 80px; font-variant-numeric: tabular-nums;">
                                {{ log.createdAt|format_datetime('short', 'short', locale='fr') }}
                            </span>
                            <span style="flex: 1;">
                                <strong>{{ log.actor.fullName }}</strong>
                                {% if log.eventType == 'comment.created' %}
                                    a commenté
                                    {% if log.project %}<a href="{{ path('app_projects_show', {reference: log.project.reference}) }}">{{ log.project.reference }}</a>{% endif %}
                                    {% if log.payload.comment_excerpt %}
                                        <span class="text-soft">— « {{ log.payload.comment_excerpt }}… »</span>
                                    {% endif %}
                                {% else %}
                                    {{ log.eventType }}
                                {% endif %}
                            </span>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </section>
    </div>
{% endblock %}
