<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Atelier{% endblock %} — Maison</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><circle cx=%2216%22 cy=%2216%22 r=%229%22 fill=%22none%22 stroke=%22%23B8935A%22 stroke-width=%221.5%22/></svg>">

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body data-controller="mobile-menu">
        <div class="app">
            <aside class="sidebar" data-mobile-menu-target="sidebar">
                <button type="button" class="sidebar__close" data-action="mobile-menu#close" aria-label="Fermer le menu">
                    {{ ux_icon('lucide:x') }}
                </button>
                <div class="sidebar__brand">
                    Maison
                    <small>Atelier</small>
                </div>
                <nav class="sidebar__nav">
                    <a href="{{ path('app_home') }}" class="sidebar__link sidebar__link--active">
                        {{ ux_icon('lucide:layout-dashboard') }} Tableau de bord
                    </a>
                    <a href="{{ path('app_projects_index') }}" class="sidebar__link {{ app.request.attributes.get('_route') starts with 'app_projects' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:gem') }} Projets
                    </a>
                    <a href="{{ path('app_clients_index') }}" class="sidebar__link {{ app.request.attributes.get('_route') starts with 'app_clients' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:users') }} Clients
                    </a>
                    <a href="{{ path('app_finances_dashboard') }}" class="sidebar__link {{ app.request.attributes.get('_route') starts with 'app_finances' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:receipt') }} Finances
                    </a>
                    <a href="{{ path('app_catalogues_index') }}" class="sidebar__link {{ app.request.attributes.get('_route') starts with 'app_catalogues' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:package') }} Catalogues
                    </a>
                    <a href="{{ path('app_projects_kanban') }}" class="sidebar__link {{ app.request.attributes.get('_route') == 'app_projects_kanban' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:columns-3') }} Kanban
                    </a>
                    <a href="{{ path('app_projects_calendar') }}" class="sidebar__link {{ app.request.attributes.get('_route') == 'app_projects_calendar' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:calendar') }} Calendrier
                    </a>
                    <a href="{{ path('app_notifications_prefs') }}" class="sidebar__link {{ app.request.attributes.get('_route') == 'app_notifications_prefs' ? 'sidebar__link--active' }}">
                        {{ ux_icon('lucide:bell') }} Notifications
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_settings') }}" class="sidebar__link {{ app.request.attributes.get('_route') starts with 'app_admin' ? 'sidebar__link--active' }}">
                            {{ ux_icon('lucide:settings') }} Paramètres
                        </a>
                    {% endif %}
                </nav>
            </aside>
            <div class="sidebar__backdrop" data-mobile-menu-target="backdrop" data-action="click->mobile-menu#close"></div>

            <div class="main">
                <header class="topbar">
                    <button type="button" class="topbar__menu" data-action="mobile-menu#open" aria-label="Ouvrir le menu">
                        {{ ux_icon('lucide:menu') }}
                    </button>
                    <div class="topbar__search text-muted text-sm">Recherche (cmd+K) — bientôt</div>
                    <div class="topbar__user">
                        {% if app.user %}
                            <span class="topbar__user-name">Bonjour, {{ app.user.firstName }}</span>
                            {{ ux_icon('lucide:circle-user-round', {width: 28, height: 28}) }}
                            <a href="{{ path('app_logout') }}" class="btn btn--ghost" title="Se déconnecter">
                                {{ ux_icon('lucide:log-out') }}
                            </a>
                        {% endif %}
                    </div>
                </header>

                <main class="page">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
