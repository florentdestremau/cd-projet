{% extends 'base.html.twig' %}
{% block title %}{{ quote.reference }}{% endblock %}
{% block body %}
    <div class="page__header">
        <div>
            <p class="text-xs text-muted" style="letter-spacing: 0.16em; text-transform: uppercase;">
                <a href="{{ path('app_projects_show', {reference: quote.project.reference}) }}">{{ quote.project.reference }}</a> · {{ quote.project.title }}
            </p>
            <h1 class="page__title">{{ quote.reference }}</h1>
            <p class="page__subtitle">Devis {{ quote.status.label|lower }}</p>
        </div>
        <div class="page__actions">
            <a href="{{ path('app_quotes_pdf', {reference: quote.reference}) }}" class="btn btn--secondary" target="_blank">PDF</a>
            {% if quote.status.value != 'accepted' %}
                <form method="post" action="{{ path('app_quotes_status', {reference: quote.reference}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('quote_status_' ~ quote.id) }}">
                    {% if quote.status.value == 'draft' %}
                        <button name="status" value="sent" class="btn btn--secondary">Marquer envoyé</button>
                    {% elseif quote.status.value == 'sent' %}
                        <button name="status" value="accepted" class="btn btn--primary">Marquer accepté</button>
                        <button name="status" value="declined" class="btn btn--ghost">Refusé</button>
                    {% endif %}
                </form>
            {% endif %}
        </div>
    </div>

    <article class="card">
        <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--color-line);">
                <th style="text-align: left; padding: var(--space-2); font-family: var(--font-serif); font-style: italic; font-weight: 400;">Description</th>
                <th style="text-align: right; padding: var(--space-2); font-family: var(--font-serif); font-style: italic; font-weight: 400;">Qté</th>
                <th style="text-align: right; padding: var(--space-2); font-family: var(--font-serif); font-style: italic; font-weight: 400;">PU HT</th>
                <th style="text-align: right; padding: var(--space-2); font-family: var(--font-serif); font-style: italic; font-weight: 400;">Total HT</th>
            </tr></thead>
            <tbody>
            {% for item in quote.items %}
                <tr style="border-bottom: 1px solid var(--color-line);">
                    <td style="padding: var(--space-2);">{{ item.description }}</td>
                    <td style="padding: var(--space-2); text-align: right;">{{ item.quantity }}</td>
                    <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (item.unitPriceHt / 100)|format_currency('EUR', locale='fr') }}</td>
                    <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (item.totalHt / 100)|format_currency('EUR', locale='fr') }}</td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
                <tr><td colspan="3" style="text-align: right; padding: var(--space-3); color: var(--color-ink-muted);">Total HT</td><td style="text-align: right; padding: var(--space-3); font-variant-numeric: tabular-nums;">{{ (quote.totalHt / 100)|format_currency('EUR', locale='fr') }}</td></tr>
                <tr><td colspan="3" style="text-align: right; padding: var(--space-3); color: var(--color-ink-muted);">TVA {{ (quote.vatRate / 100)|number_format(2, ',', ' ') }} %</td><td style="text-align: right; padding: var(--space-3); font-variant-numeric: tabular-nums;">{{ ((quote.totalTtc - quote.totalHt) / 100)|format_currency('EUR', locale='fr') }}</td></tr>
                <tr><td colspan="3" style="text-align: right; padding: var(--space-3); font-weight: 600;">Total TTC</td><td style="text-align: right; padding: var(--space-3); font-variant-numeric: tabular-nums; font-weight: 600; font-size: var(--text-lg);">{{ (quote.totalTtc / 100)|format_currency('EUR', locale='fr') }}</td></tr>
            </tfoot>
        </table>
    </article>
{% endblock %}
