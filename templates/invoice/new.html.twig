{% extends 'base.html.twig' %}
{% block title %}Nouvelle facture{% endblock %}
{% block body %}
    <div class="page__header">
        <div>
            <p class="text-xs text-muted" style="letter-spacing: 0.16em; text-transform: uppercase;">{{ project.reference }} · {{ project.title }}</p>
            <h1 class="page__title">Nouvelle facture</h1>
        </div>
    </div>

    {% if accepted_quotes|length > 0 %}
        <article class="card" style="margin-bottom: var(--space-5);">
            <h3 class="card__title">Facturer un devis accepté</h3>
            <p class="text-sm text-soft">Les lignes du devis seront copiées dans la facture.</p>
            <div style="display: flex; gap: var(--space-3); margin-top: var(--space-3); flex-wrap: wrap;">
                {% for q in accepted_quotes %}
                    <form method="post" action="{{ path('app_invoices_from_quote', {reference: q.reference}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('quote_invoice_' ~ q.id) }}">
                        <button type="submit" class="btn btn--secondary">{{ q.reference }} — {{ (q.totalTtc / 100)|format_currency('EUR', locale: 'fr') }}</button>
                    </form>
                {% endfor %}
            </div>
        </article>
    {% endif %}

    {{ form_start(form, {attr: {class: 'card form'}}) }}
        <div class="grid-2">
            {{ form_row(form.dueDate) }}
            {{ form_row(form.vatRate) }}
        </div>
        <h3 class="card__title">Lignes</h3>
        <div data-controller="form-collection" data-form-collection-prototype-value="{{ form_widget(form.items.vars.prototype)|e('html_attr') }}">
            <div data-form-collection-target="items" class="stack">
                {% for item in form.items %}
                    <div class="form__collection-row">
                        {{ form_row(item.description) }}
                        {{ form_row(item.quantity) }}
                        {{ form_row(item.unitPriceHt) }}
                    </div>
                {% endfor %}
            </div>
            <button type="button" class="btn btn--ghost" data-action="form-collection#add">+ Ligne</button>
        </div>
        <div class="form__actions">
            <a href="{{ path('app_projects_show', {reference: project.reference}) }}" class="btn btn--ghost">Annuler</a>
            <button type="submit" class="btn btn--primary">Créer la facture</button>
        </div>
    {{ form_end(form) }}
{% endblock %}
