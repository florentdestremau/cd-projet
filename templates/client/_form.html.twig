<form method="post" action="{{ action }}" class="card stack" style="max-width: 720px;">
    <input type="hidden" name="_token" value="{{ csrf_token(token_id) }}">

    <div>
        <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Nom *</label>
        <input type="text" name="displayName" value="{{ client.displayName ?? '' }}" required
               style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory);">
    </div>
    <div>
        <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Société</label>
        <input type="text" name="companyName" value="{{ client.companyName ?? '' }}"
               style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory);">
    </div>
    <div class="grid-2">
        <div>
            <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Email</label>
            <input type="email" name="contactEmail" value="{{ client.contactEmail ?? '' }}"
                   style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory);">
        </div>
        <div>
            <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Téléphone</label>
            <input type="text" name="contactPhone" value="{{ client.contactPhone ?? '' }}"
                   style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory);">
        </div>
    </div>
    <div>
        <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Adresse</label>
        <textarea name="address" rows="3"
                  style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory); font-family: var(--font-sans);">{{ client.address ?? '' }}</textarea>
    </div>
    <div>
        <label class="text-xs text-muted" style="display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2);">Notes confidentielles</label>
        <textarea name="notes" rows="3"
                  style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-ivory); font-family: var(--font-sans);">{{ client.notes ?? '' }}</textarea>
    </div>

    <div style="display: flex; justify-content: flex-end; gap: var(--space-3);">
        <a href="{{ path('app_clients_index') }}" class="btn btn--ghost">Annuler</a>
        <button type="submit" class="btn btn--primary">Enregistrer</button>
    </div>
</form>
