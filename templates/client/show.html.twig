{% extends 'base.html.twig' %}
{% block title %}{{ client.displayName }}{% endblock %}
{% block body %}
    <div class="page__header">
        <div>
            <p class="text-xs text-muted" style="letter-spacing: 0.16em; text-transform: uppercase;">Client</p>
            <h1 class="page__title">{{ client.displayName }}</h1>
            {% if client.companyName %}<p class="page__subtitle">{{ client.companyName }}</p>{% endif %}
        </div>
        <div class="page__actions">
            <a href="{{ path('app_clients_edit', {id: client.id}) }}" class="btn btn--secondary">{{ ux_icon('lucide:pencil') }} Modifier</a>
        </div>
    </div>

    <div class="grid-2" style="grid-template-columns: 2fr 1fr; align-items: start;">
        <section class="stack">
            <article class="card">
                <h3 class="card__title">Projets ({{ projects|length }})</h3>
                {% if projects|length > 0 %}
                    <table style="width: 100%; border-collapse: collapse;">
                        <tbody>
                        {% for p in projects %}
                            <tr style="border-bottom: 1px solid var(--color-line);">
                                <td style="padding: var(--space-2);"><a href="{{ path('app_projects_show', {reference: p.reference}) }}">{{ p.reference }}</a></td>
                                <td style="padding: var(--space-2);">{{ p.title }}</td>
                                <td style="padding: var(--space-2);"><span class="tag tag--gold">{{ p.currentStage.label }}</span></td>
                                <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (p.sellingPrice / 100)|format_currency('EUR', locale: 'fr') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted">Aucun projet.</p>
                {% endif %}
            </article>

            <article class="card">
                <h3 class="card__title">Factures ({{ invoices|length }})</h3>
                {% if invoices|length > 0 %}
                    <table style="width: 100%; border-collapse: collapse;">
                        <tbody>
                        {% for i in invoices %}
                            <tr style="border-bottom: 1px solid var(--color-line);">
                                <td style="padding: var(--space-2);"><a href="{{ path('app_invoices_show', {reference: i.reference}) }}">{{ i.reference }}</a></td>
                                <td style="padding: var(--space-2);"><span class="tag">{{ i.status.label }}</span></td>
                                <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (i.totalTtc / 100)|format_currency('EUR', locale: 'fr') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted">Aucune facture.</p>
                {% endif %}
            </article>
        </section>

        <aside class="stack">
            <article class="card">
                <h3 class="card__title">Coordonnées</h3>
                <p class="text-sm">
                    {% if client.contactEmail %}<span class="text-muted">Email&nbsp;:</span> {{ client.contactEmail }}<br>{% endif %}
                    {% if client.contactPhone %}<span class="text-muted">Téléphone&nbsp;:</span> {{ client.contactPhone }}<br>{% endif %}
                    {% if client.address %}<span class="text-muted">Adresse&nbsp;:</span><br>{{ client.address|nl2br }}{% endif %}
                </p>
            </article>

            <article class="card">
                <h3 class="card__title">CA cumulé</h3>
                <p style="font-family: var(--font-serif); font-size: var(--text-3xl); color: var(--color-gold-deep); margin: var(--space-2) 0;">
                    {{ (revenue / 100)|format_currency('EUR', locale: 'fr') }}
                </p>
                <p class="text-xs text-muted">Factures payées uniquement.</p>
            </article>

            {% if client.notes %}
                <article class="card">
                    <h3 class="card__title">Notes confidentielles</h3>
                    <p class="text-sm text-soft">{{ client.notes|nl2br }}</p>
                </article>
            {% endif %}
        </aside>
    </div>
{% endblock %}
