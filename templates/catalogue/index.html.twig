{% extends 'base.html.twig' %}
{% block title %}Catalogues{% endblock %}
{% block body %}
    <div class="page__header">
        <div>
            <h1 class="page__title">Catalogues</h1>
            <p class="page__subtitle">Matières, pierres et fournisseurs.</p>
        </div>
    </div>

    <div class="stack stack--lg">
        <section>
            <h2>Matières ({{ materials|length }})</h2>
            <article class="card" style="margin-top: var(--space-3);">
                {% if materials|length > 0 %}
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead><tr style="border-bottom: 1px solid var(--color-line);">
                            <th style="text-align: left; padding: var(--space-2);">Type</th>
                            <th style="text-align: left; padding: var(--space-2);">Nom</th>
                            <th style="text-align: right; padding: var(--space-2);">€ / g</th>
                            <th style="text-align: left; padding: var(--space-2);">Fournisseur</th>
                        </tr></thead>
                        <tbody>
                        {% for m in materials %}
                            <tr style="border-bottom: 1px solid var(--color-line);">
                                <td style="padding: var(--space-2);">{{ m.type.label }}</td>
                                <td style="padding: var(--space-2);">{{ m.name }}</td>
                                <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (m.pricePerGram / 100)|format_currency('EUR', locale: 'fr') }}</td>
                                <td style="padding: var(--space-2);" class="text-soft">{{ m.supplier ? m.supplier.name : '—' }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter une matière</summary>
                    {{ form_start(material_form, {action: path('app_catalogues_material_create'), attr: {class: 'form'}}) }}
                        {{ form_row(material_form.name) }}
                        {{ form_row(material_form.type) }}
                        {{ form_row(material_form.pricePerGram) }}
                        {{ form_row(material_form.supplier) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Ajouter</button>
                        </div>
                    {{ form_end(material_form) }}
                </details>
            </article>
        </section>

        <section>
            <h2>Pierres ({{ stones|length }})</h2>
            <article class="card" style="margin-top: var(--space-3);">
                {% if stones|length > 0 %}
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead><tr style="border-bottom: 1px solid var(--color-line);">
                            <th style="text-align: left; padding: var(--space-2);">Type</th>
                            <th style="text-align: right; padding: var(--space-2);">Carats</th>
                            <th style="text-align: left; padding: var(--space-2);">Qualité</th>
                            <th style="text-align: left; padding: var(--space-2);">Couleur</th>
                            <th style="text-align: right; padding: var(--space-2);">Coût</th>
                            <th style="text-align: left; padding: var(--space-2);">Fournisseur</th>
                        </tr></thead>
                        <tbody>
                        {% for s in stones %}
                            <tr style="border-bottom: 1px solid var(--color-line);">
                                <td style="padding: var(--space-2);">{{ s.type.label }}</td>
                                <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ s.carats|number_format(3, ',', ' ') }}</td>
                                <td style="padding: var(--space-2);" class="text-soft">{{ s.quality ?? '—' }}</td>
                                <td style="padding: var(--space-2);" class="text-soft">{{ s.color ?? '—' }}</td>
                                <td style="padding: var(--space-2); text-align: right; font-variant-numeric: tabular-nums;">{{ (s.costPrice / 100)|format_currency('EUR', locale: 'fr') }}</td>
                                <td style="padding: var(--space-2);" class="text-soft">{{ s.supplier ? s.supplier.name : '—' }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter une pierre</summary>
                    {{ form_start(stone_form, {action: path('app_catalogues_stone_create'), attr: {class: 'form'}}) }}
                        {{ form_row(stone_form.type) }}
                        {{ form_row(stone_form.caratWeight) }}
                        {{ form_row(stone_form.quality) }}
                        {{ form_row(stone_form.color) }}
                        {{ form_row(stone_form.certificateRef) }}
                        {{ form_row(stone_form.costPrice) }}
                        {{ form_row(stone_form.supplier) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Ajouter</button>
                        </div>
                    {{ form_end(stone_form) }}
                </details>
            </article>
        </section>

        <section>
            <h2>Fournisseurs ({{ suppliers|length }})</h2>
            <article class="card" style="margin-top: var(--space-3);">
                {% if suppliers|length > 0 %}
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead><tr style="border-bottom: 1px solid var(--color-line);">
                            <th style="text-align: left; padding: var(--space-2);">Nom</th>
                            <th style="text-align: left; padding: var(--space-2);">Spécialité</th>
                            <th style="text-align: left; padding: var(--space-2);">Contact</th>
                        </tr></thead>
                        <tbody>
                        {% for s in suppliers %}
                            <tr style="border-bottom: 1px solid var(--color-line);">
                                <td style="padding: var(--space-2);">{{ s.name }}</td>
                                <td style="padding: var(--space-2);">{{ s.specialty.label }}</td>
                                <td style="padding: var(--space-2);" class="text-soft text-sm">{{ s.contactEmail }}{% if s.contactPhone %} · {{ s.contactPhone }}{% endif %}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter un fournisseur</summary>
                    {{ form_start(supplier_form, {action: path('app_catalogues_supplier_create'), attr: {class: 'form'}}) }}
                        {{ form_row(supplier_form.name) }}
                        {{ form_row(supplier_form.specialty) }}
                        {{ form_row(supplier_form.contactEmail) }}
                        {{ form_row(supplier_form.contactPhone) }}
                        {{ form_row(supplier_form.notes) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Ajouter</button>
                        </div>
                    {{ form_end(supplier_form) }}
                </details>
            </article>
        </section>
    </div>
{% endblock %}
