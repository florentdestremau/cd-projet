{% extends 'base.html.twig' %}
{% block title %}{{ project.reference }} — {{ project.title }}{% endblock %}

{% block stylesheets %}
    {{ turbo_refresh_method('morph') }}
    {{ turbo_refresh_scroll('preserve') }}
{% endblock %}

{% block body %}
    <div class="page__header">
        <div>
            <p class="text-xs text-muted" style="letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: var(--space-2);">{{ project.reference }}</p>
            <h1 class="page__title">{{ project.title }}</h1>
            <p class="page__subtitle">
                Pour <strong>{{ project.client.displayName }}</strong>
                {% if project.targetDeliveryDate %} · Livraison prévue le {{ project.targetDeliveryDate|format_date('long', locale: 'fr') }}{% endif %}
            </p>
        </div>
        <div class="page__actions">
            <span class="tag tag--gold">{{ project.currentStage.label }}</span>
        </div>
    </div>

    <section style="margin-bottom: var(--space-7);">
        <h6 style="margin-bottom: var(--space-3);">Étapes</h6>
        <div style="display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap;">
            {% for stage in stages %}
                {% set status = project.stageStatuses|filter(s => s.stage == stage)|first %}
                {% set done = status and status.completedAt is not null %}
                {% set current = stage == project.currentStage %}
                {% set applicable = status is null or status.applicable %}
                <div style="display: flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-3); border: 1px solid {{ current ? 'var(--color-gold)' : 'var(--color-line)' }}; border-radius: var(--radius-sm); background-color: {{ done ? 'color-mix(in srgb, var(--color-gold) 10%, var(--color-paper))' : 'transparent' }};">
                    {% if done %}
                        {{ ux_icon('lucide:check', {width: 14, height: 14}) }}
                    {% elseif current %}
                        {{ ux_icon('lucide:circle-dot', {width: 14, height: 14}) }}
                    {% else %}
                        {{ ux_icon('lucide:circle', {width: 14, height: 14}) }}
                    {% endif %}
                    <span class="text-sm" style="color: {{ applicable ? 'var(--color-ink)' : 'var(--color-ink-muted)' }};">{{ stage.label }}</span>
                </div>
                {% if not loop.last %}<span class="text-muted">·</span>{% endif %}
            {% endfor %}
        </div>
    </section>

    <div class="grid-2" style="grid-template-columns: 1.5fr 1fr; align-items: start;">
        <section class="stack">
            <h2>Fil de discussion</h2>
            {{ turbo_stream_from(['project/' ~ project.id]) }}
            <turbo-frame id="comment-thread" target="_top">
            <div id="project-comments" class="stack">
                {% for comment in comments %}
                    {{ include('project/_comment.html.twig', {comment: comment}) }}
                {% else %}
                    <p class="text-muted">Aucun message pour le moment.</p>
                {% endfor %}
            </div>

            {{ form_start(comment_form, {action: path('app_comments_create', {reference: project.reference}), attr: {class: 'card form', 'data-controller': 'mention-autocomplete', 'data-mention-autocomplete-users-value': users_handles|json_encode, 'data-turbo-frame': 'comment-thread'}}) }}
                {{ form_label(comment_form.body) }}
                {{ form_widget(comment_form.body, {attr: {'data-mention-autocomplete-target': 'input'}}) }}
                <div data-mention-autocomplete-target="suggestions" class="mention-suggestions" hidden></div>
                {{ form_errors(comment_form.body) }}
                <div class="form__actions">
                    <button type="submit" class="btn btn--primary">Envoyer</button>
                </div>
            {{ form_end(comment_form) }}
            </turbo-frame>
        </section>

        <aside class="stack">
            <article class="card">
                <h3 class="card__title">Équipe</h3>
                <p class="text-sm">
                    <span class="text-muted">Designer&nbsp;:</span> {{ project.assignedDesigner ? project.assignedDesigner.fullName : '—' }}<br>
                    <span class="text-muted">Joaillier&nbsp;:</span> {{ project.assignedJeweler ? project.assignedJeweler.fullName : '—' }}<br>
                    <span class="text-muted">Sertisseur&nbsp;:</span> {{ project.assignedSetter ? project.assignedSetter.fullName : '—' }}
                </p>
            </article>

            <article class="card">
                <h3 class="card__title">Tâches</h3>
                {% if tasks|length > 0 %}
                    <ul class="task-list">
                        {% for task in tasks %}
                            <li class="task-list__item">
                                <form method="post" action="{{ path('app_tasks_toggle', {id: task.id}) }}" class="task-list__toggle">
                                    <input type="hidden" name="_token" value="{{ csrf_token('task_toggle_' ~ task.id) }}">
                                    <button type="submit" class="task-list__check" title="Marquer comme {{ task.completed ? 'à faire' : 'terminée' }}">
                                        {{ ux_icon(task.completed ? 'lucide:check-square' : 'lucide:square', {width: 18, height: 18}) }}
                                    </button>
                                </form>
                                <span class="task-list__title {{ task.completed ? 'task-list__title--done' }}">{{ task.title }}</span>
                                {% if task.assignee %}<span class="text-xs text-muted">{{ task.assignee.firstName }}</span>{% endif %}
                                {% if task.dueDate %}<span class="tag">{{ task.dueDate|format_date('short', locale: 'fr') }}</span>{% endif %}
                                <form method="post" action="{{ path('app_tasks_delete', {id: task.id}) }}" onsubmit="return confirm('Supprimer ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('task_delete_' ~ task.id) }}">
                                    <button type="submit" class="btn btn--ghost" style="padding: 0 var(--space-2); font-size: var(--text-xs);" title="Supprimer">×</button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted text-sm">Aucune tâche.</p>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter une tâche</summary>
                    {{ form_start(task_form, {action: path('app_tasks_create', {reference: project.reference}), attr: {class: 'form'}}) }}
                        {{ form_row(task_form.title) }}
                        {{ form_row(task_form.assignee) }}
                        {{ form_row(task_form.dueDate) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Ajouter</button>
                        </div>
                    {{ form_end(task_form) }}
                </details>
            </article>

            <article class="card">
                <h3 class="card__title">Finances</h3>
                <p class="text-sm">
                    <span class="text-muted">Budget cible&nbsp;:</span> {{ (project.budgetTarget / 100)|format_currency('EUR', locale: 'fr') }}<br>
                    <span class="text-muted">Prix de vente&nbsp;:</span> <strong>{{ (project.sellingPrice / 100)|format_currency('EUR', locale: 'fr') }}</strong><br>
                    <span class="text-muted">Dépenses imputées&nbsp;:</span> {{ (expenses_total / 100)|format_currency('EUR', locale: 'fr') }}<br>
                    <span class="text-muted">Marge prévue&nbsp;:</span> <strong style="color: {{ margin > 0 ? 'var(--color-success)' : 'var(--color-danger)' }};">{{ (margin / 100)|format_currency('EUR', locale: 'fr') }}</strong>
                </p>
                <div style="display: flex; gap: var(--space-2); margin-top: var(--space-3);">
                    <a href="{{ path('app_quotes_new', {reference: project.reference}) }}" class="btn btn--ghost" style="font-size: var(--text-xs);">+ Devis</a>
                    <a href="{{ path('app_invoices_new', {reference: project.reference}) }}" class="btn btn--ghost" style="font-size: var(--text-xs);">+ Facture</a>
                </div>
            </article>

            {% if quotes|length > 0 or invoices|length > 0 %}
                <article class="card">
                    <h3 class="card__title">Documents</h3>
                    {% for q in quotes %}
                        <p class="text-sm" style="display: flex; justify-content: space-between; padding: var(--space-1) 0;">
                            <a href="{{ path('app_quotes_show', {reference: q.reference}) }}">{{ q.reference }}</a>
                            <span><span class="tag">{{ q.status.label }}</span> <span style="font-variant-numeric: tabular-nums;">{{ (q.totalTtc / 100)|format_currency('EUR', locale: 'fr') }}</span></span>
                        </p>
                    {% endfor %}
                    {% for i in invoices %}
                        <p class="text-sm" style="display: flex; justify-content: space-between; padding: var(--space-1) 0;">
                            <a href="{{ path('app_invoices_show', {reference: i.reference}) }}">{{ i.reference }}</a>
                            <span><span class="tag tag--gold">{{ i.status.label }}</span> <span style="font-variant-numeric: tabular-nums;">{{ (i.totalTtc / 100)|format_currency('EUR', locale: 'fr') }}</span></span>
                        </p>
                    {% endfor %}
                </article>
            {% endif %}

            <article class="card">
                <h3 class="card__title">Dépenses</h3>
                {% if expenses|length > 0 %}
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        {% for e in expenses %}
                            <li style="display: flex; justify-content: space-between; align-items: baseline; padding: var(--space-1) 0; border-bottom: 1px solid var(--color-line); font-size: var(--text-sm); gap: var(--space-2);">
                                <span style="flex: 1;">{{ e.description }} <span class="text-muted">· {{ e.category.label }}{% if e.supplierName %} · {{ e.supplierName }}{% endif %}</span></span>
                                <span style="font-variant-numeric: tabular-nums;">{{ (e.amountHt / 100)|format_currency('EUR', locale: 'fr') }}</span>
                                <form method="post" action="{{ path('app_expenses_delete', {id: e.id}) }}" onsubmit="return confirm('Supprimer cette dépense ?');" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('expense_delete_' ~ e.id) }}">
                                    <button type="submit" class="btn btn--ghost" style="padding: 0 var(--space-2); font-size: var(--text-xs);" title="Supprimer">×</button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter une dépense</summary>
                    {{ form_start(expense_form, {action: path('app_expenses_create', {reference: project.reference}), attr: {class: 'form'}}) }}
                        {{ form_row(expense_form.description) }}
                        {{ form_row(expense_form.supplierName) }}
                        {{ form_row(expense_form.category) }}
                        {{ form_row(expense_form.amountHt) }}
                        {{ form_row(expense_form.vatAmount) }}
                        {{ form_row(expense_form.occurredAt) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Enregistrer</button>
                        </div>
                    {{ form_end(expense_form) }}
                </details>
            </article>

            <article class="card">
                <h3 class="card__title">Portail client</h3>
                {% if project.clientAccessToken %}
                    <p class="text-sm">Lien à partager avec votre client :</p>
                    <input type="text" readonly value="{{ url('app_portal_show', {token: project.clientAccessToken}) }}" style="width: 100%; padding: var(--space-2); border: 1px solid var(--color-line); border-radius: var(--radius-sm); background: var(--color-paper); font-size: var(--text-xs); margin: var(--space-2) 0;">
                {% else %}
                    <p class="text-muted text-sm">Aucun lien généré.</p>
                {% endif %}
                <form method="post" action="{{ path('app_projects_token', {reference: project.reference}) }}" style="margin-top: var(--space-2);">
                    <input type="hidden" name="_token" value="{{ csrf_token('token_' ~ project.id) }}">
                    <button type="submit" class="btn btn--ghost" style="font-size: var(--text-xs);">{{ project.clientAccessToken ? 'Régénérer le lien' : 'Générer un lien' }}</button>
                </form>
            </article>

            <article class="card">
                <h3 class="card__title">Avancement</h3>
                <p style="font-family: var(--font-serif); font-size: var(--text-3xl); color: var(--color-gold-deep); margin-bottom: var(--space-1);">
                    {{ project.progressPercent }}%
                </p>
                <p class="text-xs text-muted">Étapes complétées sur étapes applicables.</p>
            </article>

            <article class="card">
                <h3 class="card__title">Documents</h3>
                {% if documents|length > 0 %}
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-2);">
                        {% for d in documents %}
                            <div style="position: relative;">
                                <a href="{{ path('app_documents_download', {id: d.id}) }}" target="_blank" style="display: flex; flex-direction: column; gap: 4px; padding: var(--space-2); background-color: var(--color-ivory); border: 1px solid var(--color-line); border-radius: var(--radius-sm); font-size: var(--text-xs);">
                                    {% if d.isImage %}
                                        <img src="{{ path('app_documents_download', {id: d.id}) }}" alt="{{ d.filename }}" style="width: 100%; height: 80px; object-fit: cover; border-radius: 2px;">
                                    {% else %}
                                        <div style="height: 80px; display: grid; place-items: center; background: var(--color-paper); border-radius: 2px;">{{ ux_icon('lucide:file', {width: 28, height: 28}) }}</div>
                                    {% endif %}
                                    <strong style="font-size: var(--text-xs);">{{ d.filename|u.truncate(24, '…') }}</strong>
                                    <span class="text-muted">{{ d.category.label }} · {{ (d.size / 1024)|number_format(0) }} Ko</span>
                                </a>
                                <form method="post" action="{{ path('app_documents_delete', {id: d.id}) }}" onsubmit="return confirm('Supprimer ce document ?');" style="position: absolute; top: 4px; right: 4px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('document_delete_' ~ d.id) }}">
                                    <button type="submit" title="Supprimer" style="background: var(--color-ink); color: var(--color-ivory); border: none; border-radius: 50%; width: 22px; height: 22px; cursor: pointer; font-size: 12px;">×</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted text-sm">Aucun document.</p>
                {% endif %}
                <details class="form__details">
                    <summary class="form__summary">+ Ajouter un document</summary>
                    {{ form_start(document_upload_form, {action: path('app_documents_create', {reference: project.reference}), attr: {class: 'form', enctype: 'multipart/form-data'}}) }}
                        {{ form_row(document_upload_form.file) }}
                        {{ form_row(document_upload_form.category) }}
                        <div class="form__actions">
                            <button type="submit" class="btn btn--secondary">Envoyer</button>
                        </div>
                    {{ form_end(document_upload_form) }}
                </details>
            </article>
        </aside>
    </div>
{% endblock %}
